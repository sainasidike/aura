# Zhipu AI
ZHIPU_API_KEY=your_zhipu_api_key_here

# Vercel Postgres (auto-injected by Vercel Postgres integration)
POSTGRES_URL="postgresql://user:password@host/dbname?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://user:password@host/dbname?connect_timeout=15&sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/dbname?sslmode=require"

# Auth
AUTH_SECRET="your_jwt_secret_here"
ADMIN_PASSWORD="your_admin_password"

# Resend (optional, for email login. Dev mode uses code 1234)
# RESEND_API_KEY=re_xxxxxxxxxxxx
